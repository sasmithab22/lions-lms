{
  "version": 2,

  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },

    {
      "src": "/storage/(.*)",
      "dest": "/backend/storage/$1"
    },

    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
